{
  "name": "linecode-hot-update-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "node server/index.js",
    "dev:client": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "node server/index.js",
    "check": "npm run check:server && npm run typecheck",
    "check:server": "node --check server/index.js && node --check server/auth.js && node --check server/hot-update.js && node --check server/lanzou.js && node --check server/store.js && node --check scripts/dev.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
